  "quarters": {
    "Q1": {
      "books": [1, 2, 3],
      "focus": "Foundations - Basic grammar, sentence structure, parts of speech",
      "themes": "Building blocks of language"
    },
    "Q2": {
      "books": [4, 5, 6],
      "focus": "Building - Expanding sentences, descriptive language, punctuation",
      "themes": "Making writing more interesting"
    },
    "Q3": {
      "books": [7, 8, 9],
      "focus": "Deepening - Complex sentences, literary devices, advanced vocabulary",
      "themes": "Understanding how language works"
    },
    "Q4": {
      "books": [10, 11, 12],
      "focus": "Mastery - Application, editing, writing techniques",
      "themes": "Putting it all together"
    }
  },
